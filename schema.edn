;; mishmeret-ontology — the covenant-keeping (見守り / mishmeret ha-adam) vocabulary for
;; mimamori 見守り · ADR-2606112300 (doctrine: ADR-2606112200 D3/D6) · human-scale sibling
;; of the mishmar storage covenant (ADR-2606082100): data keeping ↔ human keeping.
;;
;; PURPOSE: the Datom vocabulary for bonds of keeping — offer → kept-signed consent →
;; content-free heartbeat → per-act-consented care-routing → relay 継ぎ → unilateral exit.
;; Goal: 誰の保持者でもない人間を作らない.
;;
;; CONSTITUTIONAL SHAPE (read first): this namespace is BOND-EDGE-ONLY. There are NO
;; person-node attributes — :mishmeret.person/* DOES NOT EXIST and the runtime validator
;; (src/mimamori/methods/bond.cljc ATTR_WHITELIST) raises on it and on any score/risk/
;; isolation/danger/rating token (G2 no-score-of-soul; ADR-2606112200 D4 yir'ah bundle).
;; The degeneration path (五人組 → 隣組 → Stasi IM → social credit) is unrepresentable,
;; not prohibited:
;;   G1 no-denunciation — :mishmeret.route/to enum = :kokoro | :wakai | :iyashi ONLY;
;;      :police / :authority / :council are NOT members (no reporting rail exists).
;;   G3 consent-bound  — no :active state without the kept's consent; decline/exit
;;      unconditional; relay does NOT carry consent (the incoming bond is :offered).
;;   G4 symmetric visibility — a bond datom is visible to BOTH parties by construction;
;;      there is no keeper-only hidden state.
;;   G5 NEVER-a-throne — queries are own-DID-only; coverage is aggregate-only (counts,
;;      never names); the WASM component is stateless (the host owns the log).
;;   G6 content-free   — :mishmeret.keep/act has exactly one member (:reached-out);
;;      observed/reported/assessed/flagged are NOT members. Private content lives only
;;      in com.etzhayyim.encrypted.* envelopes (ADR-2605181100), never a datom.
;; Append-only: every op is :db/add (永久記憶 Tier-0; exit is itself an appended fact).

{:schema/id "mishmeret-ontology"
 :schema/version "0.1.0"
 :schema/adr "2606112300"

 ;; ── bond (縁) — the covenant edge; the ONLY place a person appears is as a party ──
 :edge/attrs
 [{:attr :mishmeret.bond/keeper   :doc "keeper DID — the one who keeps watch (shomer)"}
  {:attr :mishmeret.bond/kept     :doc "kept DID — the one offered/holding the covenant; SIGNS consent/decline/exit (G3)"}
  {:attr :mishmeret.bond/state    :doc ":offered | :active | :declined | :exited | :handed-off — score/watchlist/erase are NOT members (G2; append-only)"}
  {:attr :mishmeret.bond/cycle    :doc "deterministic cycle counter (no wall clock)"}
  {:attr :mishmeret.bond/ceremony :doc "optional musubi 結 shomer-vow ceremony record ref (ADR-2606112300 §D5)"}

  ;; keep — the content-free heartbeat (G6)
  {:attr :mishmeret.keep/bond     :doc "ref → the active, consented bond"}
  {:attr :mishmeret.keep/act      :doc ":reached-out — the SINGLE representable act; no content field exists"}
  {:attr :mishmeret.keep/cycle    :doc "cycle of the act; no frequency mandate, no streak (G8 no-gamification)"}

  ;; route — per-act-consented care routing (G1/G3)
  {:attr :mishmeret.route/bond    :doc "ref → the bond the concern arises in"}
  {:attr :mishmeret.route/to      :doc ":kokoro | :wakai | :iyashi ONLY — the whole representable surface (G1)"}
  {:attr :mishmeret.route/consent :doc "true — the kept consents to THIS routing, each time (G3); false is unwritable (validator)"}
  {:attr :mishmeret.route/cycle   :doc "cycle of the routing"}

  ;; relay 継ぎ — finite keepers in succession (G5; 詩121:4 as relay)
  {:attr :mishmeret.relay/bond    :doc "ref → the bond being handed off (state → :handed-off)"}
  {:attr :mishmeret.relay/from    :doc "the keeper who sleeps"}
  {:attr :mishmeret.relay/to      :doc "the keeper who watches next — their bond starts :offered; relay does NOT carry consent (G3)"}
  {:attr :mishmeret.relay/cycle   :doc "cycle of the handoff"}]

 ;; ── aggregate readouts (G5: counts only — no DID can appear in these) ─────────
 :coverage/attrs
 [{:attr :mimamori.coverage/cycle          :doc "report cycle"}
  {:attr :mimamori.coverage/members-total  :doc "roster size"}
  {:attr :mimamori.coverage/with-keeper    :doc "members with an active keeper"}
  {:attr :mimamori.coverage/offers-pending :doc "members with a standing, unanswered offer"}
  {:attr :mimamori.coverage/unkept-count   :doc "THE GAP — a count, never a list (offer-matching reaches them directly, §D4)"}
  {:attr :mimamori.coverage/active-bonds   :doc "active bonds"}
  {:attr :mimamori.coverage/relays         :doc "completed relays 継ぎ"}]

 ;; ── social capital (moyai-family REUSE — canonical ledger semantics live in
 ;;    ADR-2606082100 Part A / SHA-pinned com.etzhayyim/moyai-ledger) ──
 :social-capital/attrs
 [{:attr :social.capital/holder :doc "the KEEPER's DID (Soulbound) — the kept side produces NO record, not even zero units (G2)"}
  {:attr :social.capital/op     :doc ":mint | :burn — transfer/gift/pool do NOT exist (moyai verbatim)"}
  {:attr :social.capital/units  :doc "integer units; redeemable-usd ≡ 0 (cash≡0 / BHI firewall); decaying (flow, not store)"}
  {:attr :social.capital/epoch  :doc "mint epoch (= heartbeat cycle)"}
  {:attr :social.capital/ref    :doc "sha256-opaque keep provenance — no kept DID anywhere; the ledger never becomes a who-keeps-whom registry"}]

 ;; ── unrepresentable (the schema's negative space, enforced by the validator) ──
 :unrepresentable
 [{:ns ":mishmeret.person/*"  :why "no person-node attributes — people appear only as parties to a covenant edge (反個人主義 ontology; G2)"}
  {:ns "score|risk|isolation|danger|rating tokens" :why "no score-of-soul (ADR-2606112200 D4); the validator raises"}
  {:ns ":mishmeret.route/to :police|:authority|:council" :why "no denunciation rail (G1; 五人組/Stasi degeneration blocked)"}
  {:ns ":db/retract"          :why "append-only — exit/decline are appended facts; erasure does not exist (永久記憶 Tier-0)"}]}
