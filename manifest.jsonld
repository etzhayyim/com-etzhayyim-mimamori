{
  "@context": {
    "@vocab": "https://etzhayyim.com/ns/actor#",
    "id": "@id",
    "type": "@type"
  },
  "id": "actor:mimamori",
  "type": "Actor",
  "name": "mimamori",
  "glyph": "見守り",
  "doctrinalName": "mishmeret ha-adam (משמרת האדם)",
  "purpose": "Covenant keeping membrane (相互保持者会) — the substrate for bonds of keeping (offer / consent / content-free heartbeat / consented care-routing / relay / unilateral exit) so that no human is left with no keeper; the human-scale sibling of the mishmar storage covenant. NEVER a surveillance, denunciation, or scoring system — the degeneration path (五人組→隣組→Stasi→social credit) is made structurally unrepresentable, not merely prohibited.",
  "status": "R1-offline (autonomous heartbeat + local kotoba commit-DAG persistence; live legs G7-gated)",
  "tier": "B",
  "adr": "2606112300",
  "dependsOnAdr": ["2606112200", "2606082100", "2606062100", "2605302357", "2605302358", "2605263400", "2605181100", "2605312345", "2605215000", "2605231525"],
  "lineage": "care-membrane lineage (musubi/wakai/kokoro) — NOT a mirror actor; human-scale sibling of mishmar storage covenant (ADR-2606082100); implements ADR-2606112200 D3 (NEVER-a-throne) + D6 (mishmeret ha-adam)",
  "substrate": {
    "state": "kotoba Datom log (ADR-2605312345) — methods/bond.py emits canonical EAVT, bond-edge-only (no person-node attrs)",
    "privateContent": "NEVER in datoms — com.etzhayyim.encrypted.* envelope only (ADR-2605181100, member-held keys)",
    "inference": "Murakumo-only (ADR-2605215000); AI assists a keeper, never IS a keeper (R2+ re-eval, G7)",
    "runtime": "kotoba pywasm actor (componentize-py) — pure-stdlib methods, no numpy"
  },
  "integrates": ["actor:kokoro", "actor:wakai", "actor:iyashi", "actor:musubi"],
  "cells": [
    {
      "id": "cell:mimamori.bond",
      "method": "methods/bond.py",
      "input": "data/seed-mimamori-bonds.json",
      "output": ["out/mimamori-datoms.kotoba.edn"],
      "pipeline": "synthetic seed → bond lifecycle replay (offer/consent/heartbeat/route/relay/exit) → append-only EAVT datoms; schema validator raises on any :mishmeret.person/* or score/risk attr (G2) and on any care-route target outside {kokoro,wakai,iyashi} (G1)",
      "doc": "covenant bond state machine — invariants enforced in code, not prose"
    },
    {
      "id": "cell:mimamori.match",
      "method": "methods/match.py",
      "input": "engine state + roster",
      "output": ["offers (bond datoms addressed to their two parties)"],
      "pipeline": "unkept roster members → least-loaded willing keepers (capacity cap, deterministic round-robin) → engine.offer per member; cooldown respected (G3); returned summary aggregate-only (G5)",
      "doc": "the §D4 offer-matching cell — reaches the unkept directly, never via a list"
    },
    {
      "id": "cell:mimamori.autorun",
      "method": "methods/autorun.py",
      "input": "data/seed-mimamori-bonds.json",
      "output": ["data/mimamori.datoms.kotoba.edn (append-only, git-ignored)"],
      "pipeline": "replay seed → match cycle (§D4) → aggregate coverage → ONE content-addressed tx appended to the local kotoba commit-DAG (sha256 prev-linked, verify_chain tamper-evident); cycle derives from log length (deterministic, resume-safe, no wall clock); NO external I/O",
      "doc": "autonomous heartbeat (ADR-2606091000 pattern) — gates enforced inside the loop by the bond validator"
    },
    {
      "id": "cell:mimamori.shakai",
      "method": "methods/shakai.py",
      "input": "engine keeping acts + moyai ledger (50-infra/etzhayyim-moyai-credit, verbatim reuse)",
      "output": [":social.capital/* datoms (Soulbound to the keeper; refs sha256-opaque)"],
      "pipeline": "content-free keeping act on a consented bond → mint 1 unit TO THE KEEPER (per-epoch cap; no mining surface) → decaying, non-transferable, cash≡0, no-vote/no-stage (moyai invariants verbatim, ADR-2606082100 Part A)",
      "doc": "keeping = wellbecoming intervention — the first actor closing the social-capital mint loop in code; live witness-quorum mint path stays G7-gated"
    },
    {
      "id": "cell:mimamori.coverage",
      "method": "methods/coverage_report.py",
      "input": "data/seed-mimamori-bonds.json",
      "output": ["out/coverage-report.md"],
      "pipeline": "roster + bonds → AGGREGATE-ONLY coverage (total/with-keeper/unkept-count/pending/active/relays); per-person output structurally absent — no DID ever appears in the report (G5, test-enforced)",
      "doc": "誰の保持者でもない人間を作らない — measured without naming anyone"
    }
  ],
  "gates": {
    "G1": "no-denunciation — care-route enum = {kokoro, wakai, iyashi} ONLY; :police / :authority / :council are NOT enum members (unrepresentable); the actor provides no automated reporting rail",
    "G2": "no-score — bond-edge-only data model; :mishmeret.person/* and any score/risk/isolation attribute raise at the schema validator; social capital mints to the KEEPER (moyai-family, ADR-2606082100 Part A reuse), never a score of the kept",
    "G3": "consent-bound — no active bond without the kept's explicit consent datom; decline/exit are single-action, unconditional, penalty-free; re-offer cooldown (anti-pestering)",
    "G4": "symmetric visibility — who keeps me is ALWAYS visible to me; there is no keeper-only hidden bond state; hidden keeping is surveillance and unrepresentable",
    "G5": "NEVER-a-throne (ADR-2606112200 D3) — no central all-persons view; queries are own-DID-only; coverage is aggregate-only",
    "G6": "content-free — keepingAttestation records the ACT only; private content never enters a datom (encrypted envelope only)",
    "G7": "outward-gated — live legs (real roster / §1.16 outreach / musubi ceremony / social-capital mint) require Council + operator DID; R0 = methods + schema + SYNTHETIC seed only (fictional DIDs, zero real persons)",
    "G8": "Murakumo-only inference; no-server-key; Wellbecoming §1.13 (no gamification of keeping — no leaderboard/streak/badge)"
  }
}
